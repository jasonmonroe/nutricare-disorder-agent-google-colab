# .env.example
# +------------------------------------------------------------------------------+
# | NUTRICARE DISORDER AGENT                                                     |
# +------------------------------------------------------------------------------+
# Example Environment file | @link https://www.dotenv.org/docs/security/env.html
# This .env file contains environment variables for the Nutricare Disorder Agent project.
# Note: This is an example used as a boiler plate template for your actual .env file.
# +------------------------------------------------------------------------------+
# 
# Groq Cloud API Key
# Documentation: https://console.groq.com/docs/quickstart
GROQ_API_KEY=

# Hugging Face User Access Token
# Documentation: https://huggingface.co/docs/huggingface_hub/package_reference/authentication
HF_TOKEN=

# Llama API / LlamaIndex Cloud Credentials 
# Documentation: https://developers.llamaindex.ai/llamaparse/general/api_key/
LLAMA_KEY=

# Mem0 Memory Platform Key
# Documentation: https://docs.mem0.ai/api-reference
MEM0_API_KEY=

# OpenAI Core Platform 
# Developer Quickstart: https://developers.openai.com/api/docs/quickstart
# API Key Dashboard: https://platform.openai.com/api-keys
# Set an alternative base path if routing requests through an internal proxy or a local server (e.g., LocalAI / Ollama)
OPENAI_API_BASE=https://openai.com
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ------------------------------------------------------------------------------
# MLOps & Experiment Tracking
# ------------------------------------------------------------------------------

# Weights & Biases API Key
# Documentation: https://docs.wandb.ai/inference/api-reference
# Key Generation: https://wandb.ai
WANDB_API_KEY=